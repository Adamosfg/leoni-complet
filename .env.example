# Copy to ".env" and fill in real values. ".env" is gitignored.

# --- Option A: single URL (overrides DB_* if set) ---
# DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/leoni_dashboard

# --- Option B: discrete DB fields (used if DATABASE_URL is unset) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=leoni_dashboard

JWT_SECRET=change-me-in-production
PORT=5000
NODE_ENV=development

CLIENT_URL=http://localhost:5173
# If NODE_ENV=production but you still need local browsers to connect, set:
# CORS_RELAXED=true

VITE_API_URL=http://localhost:5000/api

GEMINI_API_KEY=
APP_URL=http://localhost:5173
